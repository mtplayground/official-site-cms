# Runtime mode
NODE_ENV=production

# Application host/port (container listens on 0.0.0.0:8080)
HOSTNAME=0.0.0.0
PORT=8080

# Prisma SQLite database path inside container (persisted via ./data mount)
DATABASE_URL="file:/app/data/prod.sqlite"

# Initial admin seed credentials (used by `prisma db seed`)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-this-password"
